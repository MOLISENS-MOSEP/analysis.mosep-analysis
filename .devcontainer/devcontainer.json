// For format details, see https://aka.ms/vscode-remote/devcontainer.json or the definition README at
// https://github.com/microsoft/vscode-dev-containers/tree/master/containers/python-3-miniconda
{
	"name": "MOLISENSext_analysis",
	"context": "..",
	"dockerFile": "Dockerfile",
	"runArgs": [
		"--env-file",
		"${localWorkspaceFolder}/.devcontainer/.env"
	],
	"mounts": [
		// Uncomment and change the following lines to mount a directory from your local machine into the container.
		// External data:
		// "source=/path/to/external/data,target=/workspaces/MOLISENSext_analysis/data/0external,type=bind,consistency=cached",
		// Raw data:
		"source=/nas/data/raw/MOLISENSext,target=/workspaces/MOLISENSext_analysis/data/1raw,type=bind,consistency=cached",
		// Interim data:
		"source=/datalocal/chg/MOLISENSext,target=/workspaces/MOLISENSext_analysis/data/2interim,type=bind,consistency=cached",
		// Processed data:
		"source=/datalocal/chg/MOLISENSext/processed,target=/workspaces/MOLISENSext_analysis/data/3processed,type=bind,consistency=cached"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-toolsai.jupyter",
				"njpwerner.autodocstring",
				"ms-azuretools.vscode-docker",
				"mhutchie.git-graph",
				"eamodio.gitlens",
				"tomoki1207.pdf",
				"ms-azuretools.vscode-docker",
				"streetsidesoftware.code-spell-checker",
				"oderwat.indent-rainbow",
				"GitHub.vscode-pull-request-github",
				"charliermarsh.ruff",
				"ms-python.black-formatter",
				"ms-python.pylint"
			],
			"settings": {
				"python.formatting.black": true,
				"editor.formatOnSave": true,
				"[latex]": {
					"editor.wordWrap": "on",
					"editor.formatOnSave": false,
				},
				"python.pythonPath": "/opt/conda/bin/python",
				"python.linting.mypy": true,
				// "python.linting.enabled": true,
				"python.linting.flake8": false,
				"python.defaultInterpreterPath": "/opt/conda/bin/python",
				"python.linting.pylint": false,
				"autoDocstring.docstringFormat": "google",
				"cSpell.maxNumberOfProblems": 500,
				"python.dataScience.alwaysTrustNotebooks": true,
				"jupyter.alwaysTrustNotebooks": true,
				"notebook.formatOnSave.enabled": true,
				"files.watcherExclude": {
					"**/data/*/**": true
				}
			},
		},
	},
	"postCreateCommand": "chmod u+x install_dependencies.sh; ./install_dependencies.sh",
}